# Ollama
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=qwen3.5:latest
EMBEDDING_MODEL=nomic-embed-text
TEMPERATURE=0.1

# Retrieval
RETRIEVAL_MODE=hybrid  # hybrid | dense | sparse
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
TOP_K=5

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Agent
MAX_ITERATIONS=2

# LangSmith (optional)
LANGSMITH_API_KEY=
