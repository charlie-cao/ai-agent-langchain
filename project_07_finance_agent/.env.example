# .env.example — copy to .env
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=qwen3.5:latest
TEMPERATURE=0.1
AGENT_MAX_ITERATIONS=10

# Market data
PRICE_HISTORY_PERIOD=1y
MAX_NEWS_RESULTS=5

# Compliance thresholds (adjust per mandate)
RISK_FREE_RATE=0.05
MAX_POSITION_WEIGHT=0.20
VOLATILITY_WARN_THRESHOLD=0.40

# Storage
REPORTS_DIR=reports

# LangSmith (optional)
# LANGSMITH_API_KEY=your_key_here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=project_07_finance_agent
