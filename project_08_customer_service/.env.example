# .env.example — 复制为 .env 并按需修改
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=qwen3.5:latest
TEMPERATURE=0.1
AGENT_MAX_ITERATIONS=8

# 公司配置
COMPANY_NAME=智慧科技有限公司
SUPPORT_EMAIL=support@company.com

# 升级规则
ESCALATION_SENTIMENT_THRESHOLD=0.7
ESCALATION_TICKET_THRESHOLD=3

# SLA（小时）
SLA_P1_HOURS=2
SLA_P2_HOURS=8
SLA_P3_HOURS=24
SLA_P4_HOURS=72

# 知识库
KB_DIR=knowledge_base
MAX_KB_RESULTS=3

# LangSmith（可选）
# LANGSMITH_API_KEY=your_key_here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=project_08_customer_service
